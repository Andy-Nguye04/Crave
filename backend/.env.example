# Copy to .env and set your key. Do not commit .env.
GEMINI_API_KEY=

# Optional (defaults are in app/config.py)
# GEMINI_RECIPE_MODEL=gemini-2.5-flash
# Live WebSocket model (use this name; GEMINI_LIVE_MODEL in OS env is ignored).
# Bridge uses AUDIO + output_audio_transcription; UI still gets text (transcription).
# CRAVE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Also supported: gemini-2.5-flash-native-audio-preview-12-2025
# CRAVE_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:8080
